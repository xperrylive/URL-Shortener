# ─────────────────────────────────────────────────────────────────
# URL Shortener — Backend Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# PostgreSQL (Supabase in production, local docker DB for dev)
DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<project>.supabase.co:5432/postgres

# Redis (Redis Cloud in production, local docker Redis for dev)
REDIS_URL=redis://default:<password>@<host>:<port>

# JWT signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<random-32-byte-hex>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Public base URL used when constructing short links
BASE_URL=https://your-railway-app.up.railway.app

# Path to MaxMind GeoLite2-City.mmdb (downloaded separately — see README)
GEOIP_DB_PATH=/app/GeoLite2-City.mmdb

# "development" | "production"
ENVIRONMENT=development
