# ─────────────────────────────────────────────────────────────────
# URL Shortener — Backend Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# Production (Supabase):
DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<project>.supabase.co:5432/postgres
# Local dev (SQLite, no Docker needed):
# DATABASE_URL=sqlite+aiosqlite:///urlshortener.db

# ── Redis ─────────────────────────────────────────────────────────
# Production (Redis Cloud):
REDIS_URL=redis://default:<password>@<host>:<port>
# Local dev (in-memory fallback, no Redis needed):
# REDIS_URL=memory

# ── JWT / Auth ────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<random-32-byte-hex>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── URLs ──────────────────────────────────────────────────────────
# BASE_URL: public URL of this backend (used to build short links)
BASE_URL=https://your-railway-app.up.railway.app
# FRONTEND_URL: public URL of the frontend (used to redirect broken links)
FRONTEND_URL=https://your-vercel-app.vercel.app

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://your-vercel-app.vercel.app

# ── GeoIP ─────────────────────────────────────────────────────────
# Download from: https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
GEOIP_DB_PATH=/app/GeoLite2-City.mmdb

# ── Environment ───────────────────────────────────────────────────
# "development" | "production"
ENVIRONMENT=production
