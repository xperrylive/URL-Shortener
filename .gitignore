# ─────────────────────────────────────────────────────────────────
# Git ignore rules for the URL Shortener project
# ─────────────────────────────────────────────────────────────────

# Environment files — NEVER commit secrets
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
ENV/

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/
*.xml

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker
*.log

# MaxMind GeoIP database (downloaded separately — see README)
*.mmdb

# Node / Frontend
node_modules/
.next/
out/
frontend/.env.local

# SQLite dev databases — never commit these
*.db
*.db-shm
*.db-wal

# Alembic doesn't ignore versions/ — migrations should be committed
